# Copy to .env.local and fill in. Never commit .env.local.

# Password to enter the app (single shared password — "Just me" access).
APP_PASSWORD=change-me

# Random secret used to sign the session cookie. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# Airtable Personal Access Token (scopes: data.records:read, data.records:write,
# schema.bases:read) — create at https://airtable.com/create/tokens
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The base that holds your Cheat Sheets table. Find it in the API docs / URL:
# it starts with "app". https://airtable.com/api
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Mapbox public access token for the Jobs map (https://account.mapbox.com/access-tokens/)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxx
